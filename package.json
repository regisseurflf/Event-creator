{
  "name": "lampli",
  "version": "1.2.0",
  "description": "L'Ampli — Planificateur d'événements culturels",
  "main": "electron/main.js",
  "author": "L'Ampli",
  "license": "MIT",
  "private": true,
  "scripts": {
    "electron:dev": "electron .",
    "frontend:build": "cd frontend && npm run build",
    "dist": "bash build-backend.sh && npm run frontend:build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "backend:build": "bash build-backend.sh"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "fr.lampli.app",
    "productName": "L'Ampli",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns"
    },
    "dmg": {
      "title": "L'Ampli"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/backend/",
        "to": "backend/",
        "filter": [
          "lampli-server"
        ]
      }
    ],
    "asar": true
  }
}